# Frontend Supabase config (public values)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Optional frontend API config
VITE_API_BASE_URL="/api"

# PayPal client ID (public — safe to expose in frontend)
# Same value as PAYPAL_CLIENT_ID in server/.env
VITE_PAYPAL_CLIENT_ID="replace-with-paypal-client-id"

# Local Postgres (only if you run DB from root scripts)
DATABASE_URL="postgresql://aiads:aiads_local_dev@localhost:5432/aiads?schema=public"
