generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadRole {
  publisher
  advertiser
  demo
  general
}

enum LeadStatus {
  new
  contacted
  qualified
  archived
}

enum AdFormat {
  text
  card
  banner
}

enum AdEventType {
  impression
  click
  revenue
}

enum OrganizationType {
  advertiser
  publisher
  admin
}

enum OrganizationMemberRole {
  advertiser_owner
  advertiser_member
  advertiser_finance
  publisher_owner
  publisher_dev
  publisher_ops
  reviewer
  admin
  super_admin
}

enum BotEnvironment {
  development
  staging
  production
}

enum BotHealth {
  healthy
  warning
  degraded
}

model Lead {
  id        String     @id @default(cuid())
  role      LeadRole   @default(general)
  name      String
  email     String
  company   String?
  message   String?
  source    String?
  status    LeadStatus @default(new)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([role, createdAt])
  @@map("leads")
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String
  defaultOrganizationId String?
  defaultOrganization   Organization?        @relation("DefaultOrganization", fields: [defaultOrganizationId], references: [id], onDelete: SetNull)
  memberships           OrganizationMember[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([email])
  @@map("users")
}

model Organization {
  id               String               @id @default(cuid())
  name             String
  type             OrganizationType
  members          OrganizationMember[]
  usersWithDefault User[]               @relation("DefaultOrganization")
  publisherBots    PublisherBot[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([type, createdAt])
  @@map("organizations")
}

model OrganizationMember {
  id             String                 @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationMemberRole
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
  @@index([userId, role])
  @@map("organization_members")
}

model Ad {
  id          String   @id @default(cuid())
  title       String
  description String
  ctaText     String
  clickUrl    String
  imageUrl    String?
  advertiser  String
  topics      String[] @default([])
  format      AdFormat @default(card)
  isActive    Boolean  @default(true)
  weight      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      AdEvent[]

  @@index([isActive, createdAt])
  @@index([advertiser])
  @@map("ads")
}

model AdEvent {
  id        String      @id @default(cuid())
  adId      String?
  ad        Ad?         @relation(fields: [adId], references: [id], onDelete: SetNull)
  eventType AdEventType
  botId     String
  userId    String?
  topic     String?
  amount    Int?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([eventType, createdAt])
  @@index([adId, createdAt])
  @@index([botId, createdAt])
  @@map("ad_events")
}

model PublisherBot {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  publicId        String         @unique
  environment     BotEnvironment @default(production)
  health          BotHealth      @default(healthy)
  requests7d      Int            @default(0)
  fillRateHint    Float          @default(0)
  sdkErrorsHint   Int            @default(0)
  placementPolicy Json?
  isActive        Boolean        @default(true)
  sdkKeys         BotSdkKey[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, isActive])
  @@map("publisher_bots")
}

model BotSdkKey {
  id        String       @id @default(cuid())
  botId     String
  bot       PublisherBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  label     String
  tokenHash String       @unique
  prefix    String
  last4     String
  revokedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([botId, createdAt])
  @@index([botId, revokedAt])
  @@map("bot_sdk_keys")
}
