generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadRole {
  publisher
  advertiser
  demo
  general
}

enum LeadStatus {
  new
  contacted
  qualified
  archived
}

enum AdFormat {
  text
  card
  banner
}

enum AdEventType {
  impression
  click
  revenue
}

enum OrganizationType {
  advertiser
  publisher
  admin
}

enum OrganizationMemberRole {
  advertiser_owner
  advertiser_member
  advertiser_finance
  publisher_owner
  publisher_dev
  publisher_ops
  reviewer
  admin
  super_admin
}

enum BotEnvironment {
  development
  staging
  production
}

enum BotHealth {
  healthy
  warning
  degraded
}

enum WalletTransactionType {
  topup
  spend
  refund
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
}

enum AuditAction {
  AD_APPROVE
  AD_REJECT
  AD_TAKEDOWN
  WALLET_TOPUP
  WALLET_SPEND
  WALLET_REFUND
  PAYOUT_REQUEST
  PAYOUT_PROCESS
  PAYOUT_STATUS_UPDATE
  PLATFORM_FEE_UPDATE
  PAYPAL_CONFIG_UPDATE
  PAYPAL_WEBHOOK_CAPTURE_REVERSED
  PAYPAL_WEBHOOK_PAYOUT_SETTLED
  RATE_TABLE_UPDATE
  BLOG_POST_CREATE
  BLOG_POST_UPDATE
  BLOG_POST_DELETE
  BLOG_POST_PUBLISH
}

model Lead {
  id        String     @id @default(cuid())
  role      LeadRole   @default(general)
  name      String
  email     String
  company   String?
  message   String?
  source    String?
  status    LeadStatus @default(new)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([role, createdAt])
  @@map("leads")
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String
  defaultOrganizationId String?
  defaultOrganization   Organization?        @relation("DefaultOrganization", fields: [defaultOrganizationId], references: [id], onDelete: SetNull)
  memberships           OrganizationMember[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([email])
  @@map("users")
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  type               OrganizationType
  members            OrganizationMember[]
  usersWithDefault   User[]               @relation("DefaultOrganization")
  publisherBots      PublisherBot[]
  walletBalanceCents Int                  @default(0)
  paypalEmail        String?
  walletTransactions WalletTransaction[]
  payoutRequests     PayoutRequest[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([type, createdAt])
  @@map("organizations")
}

model WalletTransaction {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           WalletTransactionType
  amountCents    Int
  paypalOrderId  String?               @unique
  description    String?
  createdAt      DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@map("wallet_transactions")
}

model PlatformSettings {
  id               String   @id @default(cuid())
  key              String   @unique
  value            String
  updatedAt        DateTime @updatedAt

  @@map("platform_settings")
}

model PayoutRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  amountCents    Int
  paypalEmail    String
  paypalBatchId  String?
  status         PayoutStatus @default(pending)
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@index([status, createdAt])
  @@map("payout_requests")
}

model OrganizationMember {
  id             String                 @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationMemberRole
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
  @@index([userId, role])
  @@map("organization_members")
}

model Ad {
  id          String    @id @default(cuid())
  title       String
  description String
  ctaText     String
  clickUrl    String
  imageUrl    String?
  advertiser  String
  topics      String[]  @default([])
  format      AdFormat  @default(card)
  isActive            Boolean   @default(true)
  weight              Int       @default(1)
  dailyBudgetCents    Int       @default(0)
  lifetimeBudgetCents Int       @default(0)
  endsAt              DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  events              AdEvent[]

  @@index([isActive, deletedAt, createdAt])
  @@index([advertiser, deletedAt])
  @@map("ads")
}

model AdEvent {
  id        String      @id @default(cuid())
  adId      String?
  ad        Ad?         @relation(fields: [adId], references: [id], onDelete: SetNull)
  eventType AdEventType
  botId     String
  userId    String?
  topic     String?
  amount    Int?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([eventType, createdAt])
  @@index([adId, createdAt])
  @@index([botId, createdAt])
  @@map("ad_events")
}

model PublisherBot {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  publicId        String         @unique
  environment     BotEnvironment @default(production)
  health          BotHealth      @default(healthy)
  requests7d      Int            @default(0)
  fillRateHint    Float          @default(0)
  sdkErrorsHint   Int            @default(0)
  placementPolicy Json?
  isActive        Boolean        @default(true)
  deletedAt       DateTime?
  sdkKeys         BotSdkKey[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, deletedAt, createdAt])
  @@index([organizationId, isActive, deletedAt])
  @@map("publisher_bots")
}

model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  actorUserId    String?
  organizationId String?
  resourceId     String?
  resourceType   String?
  before         Json?
  after          Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())

  @@index([action, createdAt])
  @@index([organizationId, createdAt])
  @@index([resourceId])
  @@map("audit_logs")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String
  imageUrl    String?
  category    String?
  readingTime Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("blog_posts")
}

model BotSdkKey {
  id        String       @id @default(cuid())
  botId     String
  bot       PublisherBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  label     String
  tokenHash String       @unique
  prefix    String
  last4     String
  revokedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([botId, createdAt])
  @@index([botId, revokedAt])
  @@map("bot_sdk_keys")
}

/// Usage metering for publisher Signals (POST /api/signals/score). No paywall in MVP.
model SignalEvent {
  id             String   @id @default(cuid())
  botId          String
  organizationId String?
  engine         String
  action         String
  intent         String?
  stage          String?
  safetyOk       Boolean  @default(true)
  usedLlm        Boolean  @default(false)
  latencyMs      Int?
  createdAt      DateTime @default(now())

  @@index([botId, createdAt])
  @@index([organizationId, createdAt])
  @@map("signal_events")
}
