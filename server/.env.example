# Local Postgres (Docker)
DATABASE_URL="postgresql://aiads:aiads_local_dev@localhost:5432/aiads?schema=public"

# API server
PORT=8787
API_CORS_ORIGIN="http://localhost:8080"
# Keep false by default. Set true only for local debugging when Supabase token verification is unavailable.
ALLOW_INSECURE_DEV_AUTH="false"

# Supabase token verification for portal auth headers
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# SDK / Admin keys
PRISM_API_KEY="replace-with-strong-random-key"
ADMIN_API_KEY="replace-with-strong-random-key"
# HMAC request signing — enforced by default on all SDK calls (X-Prism-Timestamp + X-Prism-Signature).
# Set =false ONLY during a migration window while old SDK clients are being updated to sign requests.
# Remove this override once all clients sign. Mismatches are logged as warnings when disabled.
# REQUIRE_SDK_HMAC=false

# Logging level (debug | info | warn | error). Defaults to info.
# LOG_LEVEL="info"

# Optional distributed rate limiting (Upstash Redis REST)
# UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"

# PayPal payment gateway (sandbox by default — change PAYPAL_MODE=live for production)
# Receive payments from advertisers: PayPal Orders API v2 (no approval required)
# Send payouts to publishers: PayPal Payouts API (requires PayPal business account approval)
# Get credentials at: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID="replace-with-paypal-client-id"
PAYPAL_CLIENT_SECRET="replace-with-paypal-client-secret"
PAYPAL_MODE="sandbox"
# Webhook ID from developer.paypal.com → Your App → Webhooks → copy "Webhook ID".
# Required for signature verification on incoming PayPal webhook events.
# Register the endpoint: https://<your-domain>/api/webhooks/paypal
# Events to subscribe: PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED,
#   PAYMENT.CAPTURE.REVERSED, PAYOUT_ITEM.SUCCEEDED, PAYOUT_ITEM.FAILED
PAYPAL_WEBHOOK_ID="replace-with-paypal-webhook-id"

# Sentry error tracking (optional — leave empty to disable)
# Get your DSN at: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=""

# Optional: Redis for BullMQ background job processing (payouts, webhooks).
# When empty or unset, jobs execute inline (synchronous fallback — no Redis required).
# Example: redis://localhost:6379 or redis://:password@host:6379
REDIS_URL=""
